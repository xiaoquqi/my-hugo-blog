---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import HeroBadge from '../components/home/HeroBadge.astro';
import HeroHeadline from '../components/home/HeroHeadline.astro';
import HeroSubtitle from '../components/home/HeroSubtitle.astro';
import HeroButton from '../components/home/HeroButton.astro';
import FeatureCard from '../components/home/FeatureCard.astro';
import FeatureGrid from '../components/home/FeatureGrid.astro';
import StatsRow from '../components/home/StatsRow.astro';
import StatItem from '../components/home/StatItem.astro';
---

<StarlightPage
  frontmatter={{
    title: '老孙正经胡说',
    pagefind: false,
    template: 'splash',
    sidebar: { hidden: true },
  }}
>
  <div class="home-hero" style="text-align: center; padding-top: 3rem;">
    <HeroBadge link="/about/">
      👋 欢迎来访
      <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </HeroBadge>

    <div style="margin-top: 1.5rem; margin-bottom: 1rem;">
      <HeroHeadline>老孙正经胡说</HeroHeadline>
    </div>

    <div style="margin-bottom: 2rem;">
      <HeroSubtitle>
        云计算技术布道者 · Ceph 中国社区联合创始人 · 阿里云 MVP · 腾讯云 TVP
      </HeroSubtitle>
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-bottom: 3rem;">
      <HeroButton text="阅读博客" link="/blog/" />
      <HeroButton text="技术教程" link="/training/" />
      <HeroButton text="热点趋势" link="/docs/" />
    </div>
  </div>

  <StatsRow>
    <StatItem number="36" label="技术博客" />
    <StatItem number="68" label="开发教程" />
    <StatItem number="10+" label="热点专题" />
  </StatsRow>

  <div style="margin-top: 3rem; margin-bottom: 2rem;">
    <FeatureGrid>
      <FeatureCard
        title="技术博客"
        subtitle="记录技术成长的点滴，涵盖云计算、存储、DevOps、AI 等领域的实践经验与思考。"
        icon=""
        link="/blog/"
        gradient="linear-gradient(135deg, rgba(59,130,246,0.08), rgba(147,51,234,0.06))"
      />
      <FeatureCard
        title="编程开发"
        subtitle="系统的编程开发教程，从 Go 语言入门到 Python gRPC，再到 OpenStack/Ceph 实战。"
        icon=""
        link="/training/"
        gradient="linear-gradient(135deg, rgba(34,197,94,0.08), rgba(6,182,212,0.06))"
      />
      <FeatureCard
        title="热点趋势"
        subtitle="关注云计算、AI 等前沿技术趋势，深度分析行业动态与技术演进方向。"
        icon=""
        link="/docs/"
        gradient="linear-gradient(135deg, rgba(168,85,247,0.08), rgba(236,72,153,0.06))"
      />
    </FeatureGrid>
  </div>

  <div style="margin-bottom: 3rem;">
    <FeatureGrid>
      <FeatureCard
        title="关于我"
        subtitle="万博智云联合创始人 & CTO，十年以上软件研发及团队管理经验。"
        icon=""
        link="/about/"
        gradient="linear-gradient(135deg, rgba(20,184,166,0.08), rgba(16,185,129,0.06))"
      />
      <FeatureCard
        title="RSS 订阅"
        subtitle="通过 RSS 第一时间获取最新文章推送，不错过任何一篇技术分享。"
        icon=""
        link="/blog/rss.xml"
        gradient="linear-gradient(135deg, rgba(251,146,60,0.08), rgba(251,191,36,0.06))"
      />
    </FeatureGrid>
  </div>
</StarlightPage>
