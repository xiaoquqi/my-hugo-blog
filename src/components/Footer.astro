---
import type { Props } from '@astrojs/starlight/props';
---

<footer class="sl-footer">
  <div class="beian-links">
    <a target="_blank" href="http://www.beian.gov.cn/portal/registerSystemInfo?recordcode=11010502042680" style="display: inline-flex; align-items: center; text-decoration: none; margin-right: 1rem;">
      <img src="/images/beian.png" style="height: 1.25rem; margin-right: 0.25rem;" alt="备案图标" />
      京公网安备 11010502042680号
    </a>
    <a target="_blank" href="https://beian.miit.gov.cn/" style="text-decoration: none;">
      京ICP备2024093535号-1
    </a>
  </div>
  <div style="margin-top: 0.5rem; font-size: 0.875rem; opacity: 0.7;">
    &copy; 2025 老孙正经胡说
  </div>
</footer>

<style>
  .sl-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem 1rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-4);
    border-top: 1px solid var(--sl-color-gray-6);
  }
  .beian-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }
  .beian-links a {
    color: var(--sl-color-gray-4);
  }
  .beian-links a:hover {
    color: var(--sl-color-accent);
  }
</style>
