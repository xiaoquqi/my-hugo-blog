---
interface Props {
  title: string;
  subtitle: string;
  icon: string;
  link: string;
  gradient?: string;
}

const { title, subtitle, icon, link, gradient } = Astro.props;
---

<a href={link} class="feature-card" style={gradient ? `background: ${gradient}` : ''}>
  <div class="feature-card-icon">
    <slot name="icon" />
  </div>
  <h3 class="feature-card-title">{title}</h3>
  <p class="feature-card-subtitle">{subtitle}</p>
</a>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--sl-color-gray-6);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    background: var(--sl-color-gray-7);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
    border-color: var(--sl-color-accent);
  }

  :global([data-theme='dark']) .feature-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .feature-card-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .feature-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.375rem 0;
  }

  .feature-card-subtitle {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
</style>
