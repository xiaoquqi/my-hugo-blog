---
interface Props {
  text: string;
  link: string;
}

const { text, link } = Astro.props;
---

<a href={link} class="hero-button">
  {text}
</a>

<style>
  .hero-button {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #fff;
    background: var(--sl-color-accent);
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .hero-button:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
